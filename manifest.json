{
  "id": "lidar",
  "name": "lidar",
  "display_name": "LiDAR Point Cloud Viewer",
  "version": "1.0.0",
  "description": "Visualize LiDAR point cloud data in the unified CesiumJS viewer. Download from national LiDAR providers (PNOA/CNIG) or upload custom drone flights. Includes 3D Tiles conversion, dynamic colorization, and individual tree detection.",
  "short_description": "LiDAR point cloud visualization and tree analysis",
  "author": {
    "name": "Nekazari Team",
    "email": "nekazari@artotxiki.com",
    "organization": "Nekazari"
  },
  "developer": {
    "name": "Nekazari",
    "website": "https://nekazari.artotxiki.com",
    "support_email": "nekazari@artotxiki.com"
  },
  "category": "analytics",
  "module_type": "ADDON_PAID",
  "required_plan_type": "premium",
  "pricing_tier": "PAID",
  "route_path": "/lidar",
  "label": "LiDAR",
  "icon": "layers",
  "icon_url": "assets/icon.png",
  "required_roles": ["Farmer", "TechnicalConsultant", "TenantAdmin", "PlatformAdmin"],
  "navigation": {
    "enabled": true,
    "priority": 60,
    "section": "analytics"
  },
  "dependencies": {
    "sdk_version": "^1.0.0",
    "react_version": "^18.3.1",
    "platform_version": "^2.0.0"
  },
  "permissions": {
    "api_access": [
      "/api/lidar/*"
    ],
    "storage_access": true,
    "external_requests": [
      "https://centrodedescargas.cnig.es",
      "https://www.ign.es",
      "https://filescartografia.navarra.es"
    ]
  },
  "build_config": {
    "type": "remote",
    "remote_entry_url": "/modules/lidar/assets/remoteEntry.js",
    "scope": "lidar_module",
    "exposed_module": "./App"
  },
  "nkz_validated": {
    "security_review": true,
    "i18n_complete": true,
    "css_isolated": true
  },
  "metadata": {
    "icon": "📊",
    "color": "#6366F1",
    "features": [
      "LiDAR point cloud visualization",
      "PNOA/CNIG national LiDAR data download",
      "Custom drone LAZ/LAS file upload",
      "3D Tiles conversion for CesiumJS",
      "Dynamic colorization (height, NDVI, RGB, classification)",
      "Individual tree detection and analysis",
      "Crown diameter and biomass estimation"
    ],
    "screenshots": [],
    "slots": {
      "layer-toggle": [
        {
          "id": "lidar-layer-control",
          "component": "LidarLayerControl",
          "priority": 10
        }
      ],
      "map-layer": [
        {
          "id": "lidar-cesium-layer",
          "component": "LidarLayer",
          "priority": 10
        }
      ],
      "context-panel": [
        {
          "id": "lidar-config",
          "component": "LidarConfig",
          "priority": 20,
          "showWhen": {
            "entityType": ["AgriParcel"]
          }
        }
      ]
    }
  }
}
